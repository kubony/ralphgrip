# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# MCP config (contains secrets)
.mcp.json

# vercel
.vercel

# AI agents & IDE configs
.agent/
.agents/
.claude/
.codex/
.gemini/
.omx/
.opencode/
.windsurf/
mcp-server/node_modules/
mcp-server/dist/

# fonts (downloaded at build time)
/public/fonts/*.ttf

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
.env*.local
.npm-cache
