{
  "name": "@agentgrip/mcp-server",
  "version": "0.2.0",
  "private": false,
  "description": "MCP server for AgentGrip — AI-powered project management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentgrip-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http --port 3001",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
